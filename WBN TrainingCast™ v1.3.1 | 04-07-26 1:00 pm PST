<div id="wbn-trainingcast">
  <style>
    #wbn-trainingcast{
      --bg1:#dff5ff;
      --bg2:#c8ecfb;
      --panel:#ffffff;
      --border:#b7dfef;
      --accent:#59c2eb;
      --accent-dark:#2f8eb3;
      --text:#123246;
      --muted:#426679;
      --soft:#eef9fe;
      --danger:#d9534f;
      --success:#1f9d63;
      max-width:1100px;
      margin:0 auto;
      color:var(--text);
      font-family:Arial, Helvetica, sans-serif;
      line-height:1.45;
    }
    #wbn-trainingcast *{ box-sizing:border-box; }
    #wbn-trainingcast .tc-shell{
      background:linear-gradient(180deg,var(--bg1),var(--bg2));
      border:1px solid var(--border);
      border-radius:18px;
      padding:18px;
      box-shadow:0 10px 28px rgba(18,50,70,.08);
      overflow:hidden;
    }
    #wbn-trainingcast .tc-panel{
      background:linear-gradient(180deg,#ffffff,#f8fdff);
      border:1px solid var(--border);
      border-radius:16px;
      padding:16px;
      margin-bottom:16px;
      box-shadow:0 6px 18px rgba(18,50,70,.05);
    }
    #wbn-trainingcast .tc-panel:last-child{ margin-bottom:0; }
    #wbn-trainingcast .tc-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
      margin-bottom:10px;
      flex-wrap:wrap;
    }
    #wbn-trainingcast .tc-title{
      font-size:28px;
      font-weight:700;
      margin:0;
    }
    #wbn-trainingcast .tc-subtitle{
      color:var(--muted);
      font-size:15px;
      margin:0;
    }
    #wbn-trainingcast .tc-mini-note{
      font-size:12px;
      color:var(--muted);
      background:#fff;
      border:1px solid var(--border);
      padding:6px 10px;
      border-radius:999px;
      white-space:nowrap;
    }
    #wbn-trainingcast .tc-grid{
      display:grid;
      grid-template-columns:2fr 1fr;
      gap:16px;
    }
    #wbn-trainingcast .tc-btn,
    #wbn-trainingcast button.tc-btn,
    #wbn-trainingcast a.tc-btn{
      appearance:none;
      border:none;
      text-decoration:none;
      background:var(--accent);
      color:#fff;
      padding:10px 14px;
      border-radius:10px;
      cursor:pointer;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      font-size:14px;
      font-weight:700;
    }
    #wbn-trainingcast .tc-btn:hover{ background:var(--accent-dark); }
    #wbn-trainingcast .tc-btn.secondary{ background:var(--muted); }
    #wbn-trainingcast .tc-btn.danger{ background:var(--danger); }
    #wbn-trainingcast .tc-btn.ghost{
      background:#fff;
      color:var(--text);
      border:1px solid var(--border);
    }
    #wbn-trainingcast .tc-btn.small{
      padding:7px 10px;
      font-size:12px;
      border-radius:8px;
    }
    #wbn-trainingcast .tc-toolbar{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }
    #wbn-trainingcast .tc-input,
    #wbn-trainingcast .tc-textarea,
    #wbn-trainingcast .tc-select{
      width:100%;
      min-height:46px;
      padding:10px 12px;
      border:1px solid var(--border);
      border-radius:10px;
      background:#fff;
      color:var(--text);
      font-size:14px;
      outline:none;
    }
    #wbn-trainingcast .tc-textarea{
      min-height:100px;
      resize:vertical;
      padding-top:12px;
    }
    #wbn-trainingcast .tc-label{
      font-size:12px;
      font-weight:700;
      color:var(--muted);
      margin:0 0 6px;
      display:block;
      text-transform:uppercase;
    }
    #wbn-trainingcast .tc-form-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
    }
    #wbn-trainingcast .tc-form-grid-3{
      display:grid;
      grid-template-columns:1fr 1fr 1fr;
      gap:12px;
    }
    #wbn-trainingcast .tc-form-block{ margin-bottom:12px; }
    #wbn-trainingcast .tc-session{
      border:1px solid var(--border);
      border-radius:14px;
      padding:14px;
      background:#fff;
      margin-bottom:12px;
      box-shadow:0 4px 12px rgba(18,50,70,.03);
    }
    #wbn-trainingcast .tc-session.next{
      background:linear-gradient(180deg,#ffffff,#effbff);
      border:1px solid #95d7f0;
    }
    #wbn-trainingcast .tc-session:last-child{ margin-bottom:0; }
    #wbn-trainingcast .tc-session-top{
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-start;
      margin-bottom:8px;
      flex-wrap:wrap;
    }
    #wbn-trainingcast .tc-session-title{
      font-size:19px;
      font-weight:700;
      margin:0 0 4px;
    }
    #wbn-trainingcast .tc-session-meta{
      font-size:13px;
      color:var(--muted);
      margin:0;
    }
    #wbn-trainingcast .tc-session-desc{
      margin:10px 0 12px;
      color:var(--text);
      font-size:14px;
    }
    #wbn-trainingcast .tc-badge{
      display:inline-flex;
      align-items:center;
      border-radius:999px;
      padding:6px 10px;
      font-size:11px;
      font-weight:700;
      text-transform:uppercase;
      border:1px solid var(--border);
      background:#fff;
      color:var(--muted);
      white-space:nowrap;
    }
    #wbn-trainingcast .tc-badge.live{
      color:#fff;
      background:var(--success);
      border-color:var(--success);
    }
    #wbn-trainingcast .tc-badge.upcoming{
      color:#7a4b00;
      background:#fff5e8;
      border-color:#f3d1a4;
    }
    #wbn-trainingcast .tc-empty{
      padding:18px;
      border:1px dashed var(--border);
      border-radius:14px;
      background:#fff;
      color:var(--muted);
      font-size:14px;
    }
    #wbn-trainingcast .tc-sponsors{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
    }
    #wbn-trainingcast .tc-admin-wrap{ display:none; }
    #wbn-trainingcast .tc-admin-box{
      background:#fff;
      border:1px solid var(--border);
      border-radius:14px;
      padding:14px;
      margin-bottom:12px;
    }
    #wbn-trainingcast .tc-admin-title{
      font-size:16px;
      font-weight:700;
      margin:0 0 10px;
    }
    #wbn-trainingcast .tc-admin-session{
      border:1px solid var(--border);
      border-radius:12px;
      padding:12px;
      margin-bottom:10px;
      background:#fbfeff;
    }
    #wbn-trainingcast .tc-admin-meta{
      font-size:12px;
      color:var(--muted);
      margin:4px 0 10px;
    }
    #wbn-trainingcast .tc-divider{
      height:1px;
      background:linear-gradient(90deg,transparent,var(--border),transparent);
      margin:14px 0;
    }
    #wbn-trainingcast .tc-login-msg{
      margin-top:8px;
      font-size:13px;
      color:var(--danger);
    }
    #wbn-trainingcast .tc-ticker-wrap{
      background:#ffffff;
      border:1px solid var(--border);
      border-radius:14px;
      padding:10px 14px;
      overflow:hidden;
      position:relative;
      box-shadow:0 4px 12px rgba(18,50,70,.04);
      margin-bottom:16px;
    }
    #wbn-trainingcast .tc-ticker-inner{
      white-space:nowrap;
      display:inline-block;
      padding-left:100%;
      animation:tcTickerMove 28s linear infinite;
      color:var(--text);
      font-size:14px;
      font-weight:700;
    }
    #wbn-trainingcast .tc-ticker-label{
      color:var(--accent-dark);
      margin-right:10px;
    }
    @keyframes tcTickerMove{
      0% { transform:translateX(0); }
      100% { transform:translateX(-100%); }
    }
    #wbn-trainingcast .footer-note{
      font-size:12px;
      color:var(--muted);
      margin-top:14px;
      text-align:left;
      padding-left:4px;
    }
    @media (max-width: 900px){
      #wbn-trainingcast .tc-grid{ grid-template-columns:1fr; }
      #wbn-trainingcast .tc-form-grid,
      #wbn-trainingcast .tc-form-grid-3{ grid-template-columns:1fr; }
    }
  </style>

