  <script>
    const TCF_ITEMS_KEY = 'platform_items_master';
    const TCF_SPONSOR_KEY = 'platform_sponsors_master';
    const TCF_ADMIN_OPEN_KEY = 'platform_admin_master';
    const TCF_ARCHIVE_KEY = 'platform_archive_master';
    const TCF_SETTINGS_KEY = 'platform_settings_master';
    const TCF_META_KEY = 'platform_meta_master';
    const TCF_TICKER_KEY = 'platform_ticker_master';

    const TCF_PASSWORD = '1234';
    const TCF_WINDOW_DAYS = 21;
    const TCF_DEFAULT_SETTINGS = {
      topTitle: 'Training Live – Online',
      aboutText: 'Get expert support in real time with WBN’s Help Desk – Live Online Training. Whether you\'re a member, publisher, or new user, we’re here to guide you every step of the way.'
    };
    const TCF_DEFAULT_TICKER = 'Welcome to WBN Training Live – Online.';

    function tcfRead(key, fallback){
      try{
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : fallback;
      }catch(e){
        return fallback;
      }
    }

    function tcfWrite(key, value){
      localStorage.setItem(key, JSON.stringify(value));
    }

    function tcfUid(){
      return 'id_' + Math.random().toString(36).slice(2,10) + '_' + Date.now().toString(36);
    }

    function tcfEsc(str){
      return String(str || '')
        .replace(/&/g,'&amp;')
        .replace(/</g,'&lt;')
        .replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;')
        .replace(/'/g,'&#39;');
    }

    function tcfFormat(dt){
      try{
        return dt.toLocaleString([], {
          weekday:'short',
          year:'numeric',
          month:'short',
          day:'numeric',
          hour:'numeric',
          minute:'2-digit'
        });
      }catch(e){
        return '';
      }
    }

    function tcfMakeDate(dateStr, timeStr){
      if (!dateStr) return null;
      const dt = new Date(dateStr + 'T' + (timeStr || '00:00'));
      return isNaN(dt.getTime()) ? null : dt;
    }

    function tcfAddDays(d, days){
      const x = new Date(d.getTime());
      x.setDate(x.getDate() + days);
      return x;
    }

    function tcfAddMinutes(d, mins){
      const x = new Date(d.getTime());
      x.setMinutes(x.getMinutes() + (Number(mins) || 0));
      return x;
    }

    function tcfTouch(){
      const meta = tcfRead(TCF_META_KEY, {});
      meta.lastUpdated = new Date().toISOString();
      tcfWrite(TCF_META_KEY, meta);
    }

    function tcfNormalizeItems(items){
      return (Array.isArray(items) ? items : []).map(function(item){
        return {
          id: item.id || tcfUid(),
          title: item.title || '',
          date: item.date || '',
          time: item.time || '',
          duration: item.duration || 60,
          link: item.link || '',
          desc: item.desc || '',
          recurring: item.recurring || 'no',
          createdAt: item.createdAt || new Date().toISOString()
        };
      });
    }

    function tcfGetItems(){ return tcfNormalizeItems(tcfRead(TCF_ITEMS_KEY, [])); }
    function tcfSaveItems(items){ tcfWrite(TCF_ITEMS_KEY, tcfNormalizeItems(items)); tcfTouch(); }

    function tcfGetSponsors(){
      const sponsors = tcfRead(TCF_SPONSOR_KEY, []);
      return Array.isArray(sponsors) ? sponsors : [];
    }
    function tcfSaveSponsors(sponsors){ tcfWrite(TCF_SPONSOR_KEY, Array.isArray(sponsors) ? sponsors : []); tcfTouch(); }

    function tcfGetSettings(){ return Object.assign({}, TCF_DEFAULT_SETTINGS, tcfRead(TCF_SETTINGS_KEY, {}) || {}); }
    function tcfSaveSettings(settings){ tcfWrite(TCF_SETTINGS_KEY, Object.assign({}, TCF_DEFAULT_SETTINGS, settings || {})); tcfTouch(); }

    function tcfGetTicker(){ return tcfRead(TCF_TICKER_KEY, TCF_DEFAULT_TICKER) || TCF_DEFAULT_TICKER; }
    function tcfSaveTicker(text){ tcfWrite(TCF_TICKER_KEY, text || TCF_DEFAULT_TICKER); tcfTouch(); }

    function tcfGetArchive(){
      const archive = tcfRead(TCF_ARCHIVE_KEY, []);
      return Array.isArray(archive) ? archive : [];
    }
    function tcfSaveArchive(items){ tcfWrite(TCF_ARCHIVE_KEY, Array.isArray(items) ? items : []); tcfTouch(); }

    function tcfExpandOccurrences(items){
      const now = new Date();
      const end = tcfAddDays(now, TCF_WINDOW_DAYS);
      const out = [];

      items.forEach(function(item, baseIndex){
        const start = tcfMakeDate(item.date, item.time);
        if (!start) return;
        const duration = Number(item.duration) > 0 ? Number(item.duration) : 60;

        if (item.recurring === 'weekly'){
          for (let offset = 0; offset <= TCF_WINDOW_DAYS + 7; offset += 7){
            const s = tcfAddDays(start, offset);
            const e = tcfAddMinutes(s, duration);
            if (e <= now) continue;
            if (s > end) continue;
            out.push({ ...item, occurrenceStart:s, occurrenceEnd:e, baseIndex:baseIndex });
          }
        } else {
          const s = start;
          const e = tcfAddMinutes(s, duration);
          if (e <= now) return;
          if (s > end) return;
          out.push({ ...item, occurrenceStart:s, occurrenceEnd:e, baseIndex:baseIndex });
        }
      });

      out.sort(function(a,b){ return a.occurrenceStart - b.occurrenceStart; });
      return out;
    }

    function tcfStatus(item){
      const now = new Date();
      return (now >= item.occurrenceStart && now < item.occurrenceEnd) ? 'live' : 'upcoming';
    }

    function tcfSessionCard(item, isNext){
      const status = tcfStatus(item);
      const label = status === 'live' ? 'LIVE NOW' : 'UPCOMING';
      const startLabel = tcfFormat(item.occurrenceStart);
      const endLabel = item.occurrenceEnd ? item.occurrenceEnd.toLocaleTimeString([], { hour:'numeric', minute:'2-digit' }) : '';
      const durationText = Number(item.duration) ? (Number(item.duration) + ' min') : '';
      const recurringText = item.recurring === 'weekly' ? 'Repeats weekly' : 'One-time session';

      return `
        <div class="tc-session ${isNext ? 'next' : ''}">
          <div class="tc-session-top">
            <div>
              <div class="tc-session-title">${tcfEsc(item.title || 'Untitled Training')}</div>
              <div class="tc-session-meta">
                ${tcfEsc(startLabel)}${endLabel ? ' • Ends ' + tcfEsc(endLabel) : ''}${durationText ? ' • ' + tcfEsc(durationText) : ''} • ${tcfEsc(recurringText)}
              </div>
            </div>
            <div class="tc-badge ${status === 'live' ? 'live' : 'upcoming'}">${label}</div>
          </div>
          ${item.desc ? `<div class="tc-session-desc">${tcfEsc(item.desc)}</div>` : ''}
          <div class="tc-toolbar">
            ${item.link ? `<a class="tc-btn" href="${tcfEsc(item.link)}" target="_blank" rel="noopener noreferrer">Join Training</a>` : ''}
          </div>
        </div>
      `;
    }

    function tcfDefaultSponsors(){
      const sponsors = tcfGetSponsors();
      if (sponsors.length) return sponsors;
      return [
        { id:'d1', name:'Sponsor', link:'#' },
        { id:'d2', name:'Sponsor', link:'#' },
        { id:'d3', name:'Sponsor', link:'#' }
      ];
    }

    function renderTrainingCastFix(){
      const settings = tcfGetSettings();
      document.getElementById('tcTopTitle').textContent = settings.topTitle || TCF_DEFAULT_SETTINGS.topTitle;
      document.getElementById('tcTopAbout').textContent = settings.aboutText || TCF_DEFAULT_SETTINGS.aboutText;
      document.getElementById('tcTickerText').innerHTML = '<span class="tc-ticker-label">Training Updates:</span>' + tcfEsc(tcfGetTicker());

      const occurrences = tcfExpandOccurrences(tcfGetItems());
      const nextWrap = document.getElementById('tcNextTraining');
      const listWrap = document.getElementById('tcScheduleList');

      if (!occurrences.length){
        nextWrap.innerHTML = '<div class="tc-empty">No upcoming training sessions are currently scheduled in the next 3 weeks.</div>';
        listWrap.innerHTML = '<div class="tc-empty">Add training sessions in Admin to begin building the schedule.</div>';
      } else {
        nextWrap.innerHTML = tcfSessionCard(occurrences[0], true);
        const rest = occurrences.slice(1);
        listWrap.innerHTML = rest.length ? rest.map(function(item){ return tcfSessionCard(item, false); }).join('') : '<div class="tc-empty">No additional upcoming sessions after the next training right now.</div>';
      }

      document.getElementById('tcSponsors').innerHTML = tcfDefaultSponsors().map(function(s){
        return `<a class="tc-btn secondary" href="${tcfEsc(s.link || '#')}" target="_blank" rel="noopener noreferrer">${tcfEsc(s.name || 'Sponsor')}</a>`;
      }).join('');

      renderTrainingCastAdminFix();
    }

    function renderTrainingCastAdminFix(){
      const isOpen = tcfRead(TCF_ADMIN_OPEN_KEY, false) === true;
      const adminWrap = document.getElementById('tcAdminWrap');
      const loginPanel = document.getElementById('tcLoginPanel');

      adminWrap.style.display = isOpen ? 'block' : 'none';
      loginPanel.style.display = isOpen ? 'none' : 'block';

      if (!isOpen) return;

      const settings = tcfGetSettings();
      document.getElementById('tcSettingsTitle').value = settings.topTitle || '';
      document.getElementById('tcSettingsAbout').value = settings.aboutText || '';
      document.getElementById('tcTickerInput').value = tcfGetTicker();

      const items = tcfGetItems();
      const adminList = document.getElementById('tcAdminSessionList');
      adminList.innerHTML = items.length ? items.map(function(item, index){
        const nextVisible = tcfExpandOccurrences([item]);
        const nextText = nextVisible.length ? 'Next visible: ' + tcfFormat(nextVisible[0].occurrenceStart) : 'No visible occurrence in next 3 weeks';
        return `
          <div class="tc-admin-session">
            <div class="tc-admin-title" style="margin:0;">${tcfEsc(item.title || 'Untitled Training')}</div>
            <div class="tc-admin-meta">
              Base date: ${tcfEsc(item.date || '—')} • Time: ${tcfEsc(item.time || '—')} • Duration: ${tcfEsc(String(item.duration || 60))} min • ${item.recurring === 'weekly' ? 'Weekly recurring' : 'One-time'}<br>
              ${tcfEsc(nextText)}
            </div>
            <div class="tc-toolbar">
              <button class="tc-btn small" type="button" onclick="loadSessionIntoFormTrainingCastFix(${index})">Edit</button>
              <button class="tc-btn ghost small" type="button" onclick="moveSessionTrainingCastFix(${index}, 'up')">Move Up</button>
              <button class="tc-btn ghost small" type="button" onclick="moveSessionTrainingCastFix(${index}, 'down')">Move Down</button>
              <button class="tc-btn danger small" type="button" onclick="deleteSessionTrainingCastFix(${index})">Delete</button>
            </div>
          </div>
        `;
      }).join('') : '<div class="tc-empty">No saved training sessions yet.</div>';

      const sponsors = tcfGetSponsors();
      document.getElementById('tcSponsorAdminList').innerHTML = sponsors.length ? sponsors.map(function(s, index){
        return `
          <div class="tc-admin-session">
            <div class="tc-admin-title" style="margin:0;">${tcfEsc(s.name || 'Sponsor')}</div>
            <div class="tc-admin-meta">${tcfEsc(s.link || '#')}</div>
            <div class="tc-toolbar">
              <button class="tc-btn danger small" type="button" onclick="deleteSponsorTrainingCastFix(${index})">Delete Button</button>
            </div>
          </div>
        `;
      }).join('') : '<div class="tc-empty">No custom advertisers loaded yet. Public view is showing default Sponsor buttons.</div>';
    }

    function resetSessionFormTrainingCastFix(){
      document.getElementById('tcEditIndex').value = '-1';
      document.getElementById('tcTitleInput').value = '';
      document.getElementById('tcDateInput').value = '';
      document.getElementById('tcTimeInput').value = '';
      document.getElementById('tcDurationInput').value = '60';
      document.getElementById('tcLinkInput').value = '';
      document.getElementById('tcRecurringInput').value = 'no';
      document.getElementById('tcDescInput').value = '';
    }

    function loadSessionIntoFormTrainingCastFix(index){
      const items = tcfGetItems();
      const item = items[index];
      if (!item) return;
      document.getElementById('tcEditIndex').value = String(index);
      document.getElementById('tcTitleInput').value = item.title || '';
      document.getElementById('tcDateInput').value = item.date || '';
      document.getElementById('tcTimeInput').value = item.time || '';
      document.getElementById('tcDurationInput').value = String(item.duration || 60);
      document.getElementById('tcLinkInput').value = item.link || '';
      document.getElementById('tcRecurringInput').value = item.recurring || 'no';
      document.getElementById('tcDescInput').value = item.desc || '';
    }

    function saveSessionTrainingCastFix(){
      const editIndex = Number(document.getElementById('tcEditIndex').value);
      const title = document.getElementById('tcTitleInput').value.trim();
      const date = document.getElementById('tcDateInput').value;
      const time = document.getElementById('tcTimeInput').value;
      const duration = Number(document.getElementById('tcDurationInput').value || 60);
      const link = document.getElementById('tcLinkInput').value.trim();
      const recurring = document.getElementById('tcRecurringInput').value;
      const desc = document.getElementById('tcDescInput').value.trim();

      if (!title || !date || !time){
        alert('Please add at least a title, date, and time.');
        return;
      }

      const items = tcfGetItems();
      const payload = {
        id: editIndex >= 0 && items[editIndex] ? items[editIndex].id : tcfUid(),
        title:title,
        date:date,
        time:time,
        duration:duration > 0 ? duration : 60,
        link:link,
        desc:desc,
        recurring: recurring === 'weekly' ? 'weekly' : 'no',
        createdAt: editIndex >= 0 && items[editIndex] ? items[editIndex].createdAt : new Date().toISOString()
      };

      if (editIndex >= 0 && items[editIndex]) items[editIndex] = payload;
      else items.push(payload);

      tcfSaveItems(items);
      resetSessionFormTrainingCastFix();
      renderTrainingCastFix();
    }

    function deleteSessionTrainingCastFix(index){
      const items = tcfGetItems();
      const item = items[index];
      if (!item) return;
      if (!confirm('Delete this training session?')) return;
      const removed = items.splice(index,1)[0];
      tcfSaveItems(items);
      const archive = tcfGetArchive();
      archive.unshift(Object.assign({}, removed, { archivedAt:new Date().toISOString() }));
      tcfSaveArchive(archive);
      renderTrainingCastFix();
    }

    function moveSessionTrainingCastFix(index, direction){
      const items = tcfGetItems();
      const target = direction === 'up' ? index - 1 : index + 1;
      if (target < 0 || target >= items.length) return;
      const tmp = items[index];
      items[index] = items[target];
      items[target] = tmp;
      tcfSaveItems(items);
      renderTrainingCastFix();
    }

    function saveTopCopyTrainingCastFix(){
      tcfSaveSettings({
        topTitle: document.getElementById('tcSettingsTitle').value.trim() || TCF_DEFAULT_SETTINGS.topTitle,
        aboutText: document.getElementById('tcSettingsAbout').value.trim() || TCF_DEFAULT_SETTINGS.aboutText
      });
      renderTrainingCastFix();
    }

    function saveTickerTrainingCastFix(){
      tcfSaveTicker(document.getElementById('tcTickerInput').value.trim() || TCF_DEFAULT_TICKER);
      renderTrainingCastFix();
    }

    function addSponsorTrainingCastFix(){
      const name = document.getElementById('tcSponsorName').value.trim();
      const link = document.getElementById('tcSponsorLink').value.trim();
      if (!name || !link){
        alert('Please add both button text and a button link.');
        return;
      }
      const sponsors = tcfGetSponsors();
      sponsors.push({ id:tcfUid(), name:name, link:link });
      tcfSaveSponsors(sponsors);
      document.getElementById('tcSponsorName').value = '';
      document.getElementById('tcSponsorLink').value = '';
      renderTrainingCastFix();
    }

    function deleteSponsorTrainingCastFix(index){
      const sponsors = tcfGetSponsors();
      sponsors.splice(index,1);
      tcfSaveSponsors(sponsors);
      renderTrainingCastFix();
    }

    function exportBackupTrainingCastFix(){
      const payload = {
        version:'WBN TrainingCast™ v1.3.1',
        exportedAt:new Date().toISOString(),
        items:tcfGetItems(),
        sponsors:tcfGetSponsors(),
        settings:tcfGetSettings(),
        ticker:tcfGetTicker(),
        archive:tcfGetArchive(),
        meta:tcfRead(TCF_META_KEY,{})
      };
      const blob = new Blob([JSON.stringify(payload, null, 2)], { type:'application/json' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'trainingcast_backup_v1_3_1.json';
      document.body.appendChild(a);
      a.click();
      setTimeout(function(){ URL.revokeObjectURL(a.href); a.remove(); }, 250);
    }

    function importBackupTrainingCastFix(file){
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(evt){
        try{
          const data = JSON.parse(evt.target.result);
          tcfSaveItems(Array.isArray(data.items) ? data.items : []);
          tcfSaveSponsors(Array.isArray(data.sponsors) ? data.sponsors : []);
          tcfSaveSettings(data.settings || TCF_DEFAULT_SETTINGS);
          tcfSaveTicker(data.ticker || TCF_DEFAULT_TICKER);
          tcfSaveArchive(Array.isArray(data.archive) ? data.archive : []);
          tcfWrite(TCF_META_KEY, data.meta || {});
          renderTrainingCastFix();
          alert('Data uploaded successfully.');
        }catch(e){
          alert('Upload failed. Please use a valid TrainingCast data file.');
        }
      };
      reader.readAsText(file);
    }

    function loginTrainingCastFix(){
      const pass = (document.getElementById('tcAdminPass').value || '').trim();
      const msg = document.getElementById('tcLoginMsg');
      const adminWrap = document.getElementById('tcAdminWrap');
      const loginPanel = document.getElementById('tcLoginPanel');

      if (pass === TCF_PASSWORD){
        tcfWrite(TCF_ADMIN_OPEN_KEY, true);
        adminWrap.style.display = 'block';
        loginPanel.style.display = 'none';
        document.getElementById('tcAdminPass').value = '';
        msg.textContent = '';
        renderTrainingCastAdminFix();
      } else {
        msg.textContent = 'Incorrect password.';
      }
    }

    function logoutTrainingCastFix(){
      tcfWrite(TCF_ADMIN_OPEN_KEY, false);
      document.getElementById('tcAdminWrap').style.display = 'none';
      document.getElementById('tcLoginPanel').style.display = 'block';
    }

    function seedTrainingCastFix(){
      if (tcfRead(TCF_ITEMS_KEY, null) === null) tcfWrite(TCF_ITEMS_KEY, []);
      if (tcfRead(TCF_SPONSOR_KEY, null) === null) tcfWrite(TCF_SPONSOR_KEY, []);
      if (tcfRead(TCF_ARCHIVE_KEY, null) === null) tcfWrite(TCF_ARCHIVE_KEY, []);
      if (tcfRead(TCF_SETTINGS_KEY, null) === null) tcfWrite(TCF_SETTINGS_KEY, TCF_DEFAULT_SETTINGS);
      if (tcfRead(TCF_TICKER_KEY, null) === null) tcfWrite(TCF_TICKER_KEY, TCF_DEFAULT_TICKER);
      if (tcfRead(TCF_META_KEY, null) === null) tcfWrite(TCF_META_KEY, { initializedAt:new Date().toISOString() });
      if (tcfRead(TCF_ADMIN_OPEN_KEY, null) === null) tcfWrite(TCF_ADMIN_OPEN_KEY, false);
    }

    seedTrainingCastFix();
    renderTrainingCastFix();

    var tcImportInput = document.getElementById('tcImportInput');
    if (tcImportInput){
      tcImportInput.addEventListener('change', function(e){
        const file = e.target.files && e.target.files[0] ? e.target.files[0] : null;
        importBackupTrainingCastFix(file);
        e.target.value = '';
      });
    }

    var tcPass = document.getElementById('tcAdminPass');
    if (tcPass){
      tcPass.addEventListener('keydown', function(e){
        if (e.key === 'Enter') loginTrainingCastFix();
      });
    }
  </script>
</div>
